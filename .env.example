# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://autohire:yourpassword@localhost:5432/autohire?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# MUST be changed in production!
JWT_SECRET="CHANGE_THIS_TO_A_64_CHARACTER_RANDOM_HEX_STRING_IN_PRODUCTION_PLEASE"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
